<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.controllers.ChangePasswordController"
      spacing="12"
      styleClass="page-card">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Change Password" styleClass="page-title"/>
    <Label fx:id="lblUser" text="User:"/>

    <HBox fx:id="rowAdminTarget" spacing="10" alignment="CENTER_LEFT">
        <Label text="Target Username/ID"/>
        <TextField fx:id="tfTargetUser" promptText="e.g. D4321 or 528850..." HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="lblOldTitle" text="Current Password"/>

    <StackPane>
        <PasswordField fx:id="pfOld" promptText="Current password" prefWidth="320"/>
        <TextField fx:id="tfOldVisible" promptText="Current password" prefWidth="320"
                   visible="false" managed="false"/>
        <Button text="👁" onAction="#toggleOldPassword"
                StackPane.alignment="CENTER_RIGHT" styleClass="icon-button"/>
    </StackPane>

    <Label text="New Password"/>

    <StackPane>
        <PasswordField fx:id="pfNew" promptText="New password" prefWidth="320"/>
        <TextField fx:id="tfNewVisible" promptText="New password" prefWidth="320"
                   visible="false" managed="false"/>
        <Button text="👁" onAction="#toggleNewPassword"
                StackPane.alignment="CENTER_RIGHT" styleClass="icon-button"/>
    </StackPane>

    <Label text="Confirm New Password"/>

    <StackPane>
        <PasswordField fx:id="pfConfirm" promptText="Confirm new password" prefWidth="320"/>
        <TextField fx:id="tfConfirmVisible" promptText="Confirm new password" prefWidth="320"
                   visible="false" managed="false"/>
        <Button text="👁" onAction="#toggleConfirmPassword"
                StackPane.alignment="CENTER_RIGHT" styleClass="icon-button"/>
    </StackPane>

    <Button text="Save New Password" onAction="#onSave" styleClass="btn-primary"/>

    <Label fx:id="lblInfo" styleClass="muted"/>

</VBox>

