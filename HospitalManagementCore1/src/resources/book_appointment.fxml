<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
     fx:controller="ui.controllers.BookAppointmentController"
      spacing="16"
      styleClass="page-bg">

    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <!-- Title -->
    <VBox spacing="6">
        <Label text="Book Appointment" styleClass="page-title"/>
        <Label text="Select department, doctor, patient, date and time."
               styleClass="muted"/>
    </VBox>

    <!-- Content: left form + right slots -->
    <HBox spacing="22">

        <!-- LEFT: FORM -->
        <GridPane hgap="14" vgap="14" HBox.hgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Department -->
            <Label text="Department:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbDepartment"
                      prefWidth="420"
                      maxWidth="Infinity"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <!-- Doctor -->
            <Label text="Doctor:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbDoctor"
                      prefWidth="420"
                      maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Patient (Admin mode için) -->
          <Label fx:id="lblPatient" text="Patient:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
<ComboBox fx:id="cbPatient" GridPane.rowIndex="2" GridPane.columnIndex="1"/>



            <!-- Date -->
            <Label text="Date:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpDate"
                        prefWidth="420"
                        maxWidth="Infinity"
                        GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Buttons -->
            <HBox spacing="12" GridPane.rowIndex="4" GridPane.columnIndex="1">
                <Button text="Book Appointment"
                        onAction="#onBook"
                        styleClass="btn-primary"/>
            </HBox>

            <!-- Info -->
            <Label fx:id="lblInfo"
                   text=""
                   wrapText="true"
                   styleClass="muted"
                   GridPane.rowIndex="5"
                   GridPane.columnIndex="1"/>
        </GridPane>

        <!-- RIGHT: TIME SLOTS -->
        <VBox spacing="10" prefWidth="260">
            <Label text="Available Times" styleClass="section-title"/>

            <ListView fx:id="lvSlots"
          onMouseClicked="#onSlotsClicked"
          prefHeight="260"/>


            <Label text="Tip: Choose a time from the list."
                   wrapText="true"
                   styleClass="muted"/>
        </VBox>

    </HBox>

</VBox>
