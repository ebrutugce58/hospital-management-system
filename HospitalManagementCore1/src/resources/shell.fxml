<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.ShellController">

    <left>
        <VBox fx:id="sidebar" spacing="14" prefWidth="240" styleClass="sidebar">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>

            <!-- LOGO / HEADER -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="sidebar-header">
                <Label text="🏥" styleClass="sidebar-logo"/>
                <VBox>
                    <Label text="Hospital" styleClass="sidebar-title"/>
                    <Label text="Management System" styleClass="sidebar-subtitle"/>
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.35;"/>

         <!-- MENU BUTTONS -->

<Button fx:id="btnRegister"
        text="Register Doctor"
        onAction="#showDoctorRegister"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

<Button fx:id="btnBook"
        text="Book Appointment"
        onAction="#showBook"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

<Button fx:id="btnCancel"
        text="Cancel Appointment"
        onAction="#showCancel"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

<Button fx:id="btnQueue"
        text="Doctor Queue"
        onAction="#showQueue"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

<Button fx:id="btnHistory"
        text="Patient History"
        onAction="#showHistory"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

<Button text="Change Password"
        onAction="#showChangePassword"
        maxWidth="Infinity"
        styleClass="menu-btn"/>

            <!-- ✅ boşluk bırak: alttaki status + logout aşağı insin -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- STATUS -->
            <Label text="Status:" style="-fx-text-fill: white; -fx-opacity: 0.8;"/>
            <Label fx:id="lblStatus"
                   text="Ready"
                   wrapText="true"
                   style="-fx-text-fill: white; -fx-font-weight: bold;"/>

            <Separator style="-fx-opacity: 0.35;"/>

            <!-- LOGOUT (en altta) -->
            <Button fx:id="btnLogout"
                    text="Logout"
                    onAction="#onLogout"
                    styleClass="menu-button btn-danger"
                    maxWidth="1.7976931348623157E308"/>




        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
